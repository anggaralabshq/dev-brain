# ─── Database ────────────────────────────────────────────────────────────────
# Local dev (Docker):
DATABASE_URL="postgresql://devbrain:devbrain_dev_only@localhost:5432/devbrain"
# Production (Neon) — get from https://console.neon.tech → Connection Details:
# DATABASE_URL="postgresql://user:pass@host.neon.tech/dbname?sslmode=require"

# ─── App URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: set to your Vercel domain, e.g. https://yourapp.vercel.app

# ─── Auth URL ─────────────────────────────────────────────────────────────────
# Leave unset when running multiple subdomains (brain.*, vault.*) behind AUTH_TRUST_HOST=true —
# Auth.js derives the origin dynamically per-request from the Host header. Setting AUTH_URL
# pins every request's origin to one host (next-auth's reqWithEnvURL), breaking login
# redirects for any other subdomain. Only set this for a genuinely single-host deployment.
# AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ─── Auth.js ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""

# ─── Access Control ──────────────────────────────────────────────────────────
# Only this GitHub username can sign in. Leave blank to allow anyone.
ALLOWED_GITHUB_LOGIN=""

# ─── GitHub OAuth ────────────────────────────────────────────────────────────
# Create at https://github.com/settings/developers → OAuth Apps
# Callback URL (local):  http://localhost:3000/api/auth/callback/github
# Callback URL (prod):   https://yourapp.vercel.app/api/auth/callback/github
GITHUB_ID=""
GITHUB_SECRET=""

# GitHub OAuth Apps only allow one registered callback URL. If you run more than
# one subdomain (brain.*, vault.*) but only brain.*'s callback is registered on
# GitHub, set this to have other subdomains' OAuth flow proxy through it —
# Auth.js signs state and bounces the user back to the real origin after.
# Leave unset for single-subdomain deployments.
# AUTH_REDIRECT_PROXY_URL="https://brain.anggaralabs.lol/api/auth"

# ─── tldraw (optional) ───────────────────────────────────────────────────────
# Get license at https://tldraw.dev
# TLDRAW_LICENSE_KEY=""
# NEXT_PUBLIC_TLDRAW_LICENSE_KEY=""

# ─── AI Chat (Claude) ─────────────────────────────────────────────────────────
# Get API key at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-fable-5"

# ─── AI (MiniMax) ────────────────────────────────────────────────────────────
# Used by the learning-items auto-summary feature only (lib/actions/learning.ts).
# Get API key at https://platform.minimaxi.com → API Keys
MINIMAX_API_KEY=""
MINIMAX_MODEL="MiniMax-M2.7-Highspeed"
MINIMAX_API_URL="https://api.minimax.io/v1/text/chatcompletion_v2"

# ─── Superapp ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_DOMAIN="anggaralabs.lol"
NEXT_PUBLIC_DEVBRAIN_URL="https://brain.anggaralabs.lol"
NEXT_PUBLIC_VAULTKEY_URL="https://vault.anggaralabs.lol"
NEXT_PUBLIC_FOREST_URL="https://hutan.anggaralabs.lol"

# ─── Hutan Monitor ────────────────────────────────────────────────────────────
# Get from https://data-api.globalforestwatch.org (sign-up → token → apikey)
GFW_API_KEY=""
# Get from https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=""
# Create bot via @BotFather on Telegram, get token from it
TELEGRAM_BOT_TOKEN=""
# Optional — set when calling setWebhook to verify requests are really from Telegram
TELEGRAM_WEBHOOK_SECRET=""
